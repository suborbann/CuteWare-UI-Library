				})

				local Arrow = create("TextLabel", {
					Text = "‚Ėĺ",
					Font = Theme.Font,
					TextSize = 14,
					TextColor3 = Theme.SubText,
					BackgroundTransparency = 1,
					Size = UDim2.new(0, 24, 1, 0),
