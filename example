-- ============================================
-- TAB 6: FLAGS & INFO
-- ============================================
local Tab6 = Window:CreateTab({
    Name = "Flags",
    Icon = 128457643781626,
})

local Section6 = Tab6:CreateSection("Current Flags")

Section6:CreateLabel("All flag values are stored in CuteWare.Flags.")

Section6:CreateButton({
    Name     = "Print All Flags",
    Callback = function()
        print("\n=== CUTEWARE FLAGS ===")
        for flagName, value in pairs(CuteWare.Flags) do
            print(flagName .. " = " .. tostring(value))
        end
        print("=== END FLAGS ===\n")
        
        CuteWare:Notify({
            Title    = "Flags Printed",
            Content  = "Check the console for flag values.",
            Duration = 3,
        })
    end,
})

Section6:CreateButton({
    Name     = "Reset Window Position",
    Callback = function()
        -- Window can be repositioned via its internal methods
        CuteWare:Notify({
            Title    = "Reset",
            Content  = "Window position reset to default.",
            Duration = 2,
        })
    end,
})

local Section6B = Tab6:CreateSection("Configuration")

Section6B:CreateToggle({
    Name         = "Show Debug Info",
    Flag         = "DebugMode",
    CurrentValue = false,
    Callback     = function(state)
        if state then
            print("Debug mode enabled")
        else
            print("Debug mode disabled")
        end
    end,
})

Section6B:CreateLabel("Enable debug mode to see detailed console messages.")

