			------------------------------------------------------------
			-- Section:CreateSlider(config)
			-- config = {
			--   Name         = string,
			--   Range        = {min, max},    -- default {0,100}
			--   Increment    = number,        -- step size (default 1)
			--   CurrentValue = number,        -- initial value
			--   Flag         = string,
			--   Callback     = function(number)
			-- }
			------------------------------------------------------------
			function Section:CreateSlider(c)
				c = c or {}
				local mn  = c.Range and c.Range[1] or 0
				local mx  = c.Range and c.Range[2] or 100
				local inc = c.Increment or 1
				local val = c.CurrentValue or mn

				local H = create("Frame",{BackgroundTransparency=1,Size=UDim2.new(1,0,0,42),Parent=SH})
				create("TextLabel",{
					Text=c.Name or "Slider",Font=Theme.Font,TextSize=13,
					TextColor3=Theme.Text,BackgroundTransparency=1,
					Size=UDim2.new(1,-50,0,18),TextXAlignment=Enum.TextXAlignment.Left,Parent=H,
				})
				local VL = create("TextLabel",{
					Text=tostring(val),Font=Theme.Font,TextSize=13,
					TextColor3=Theme.SubText,BackgroundTransparency=1,
					Size=UDim2.new(0,50,0,18),Position=UDim2.new(1,-50,0,0),
					TextXAlignment=Enum.TextXAlignment.Right,Parent=H,
				})
				local Bar = create("Frame",{
					BackgroundColor3=Theme.Tertiary,
					Position=UDim2.new(0,0,0,26),Size=UDim2.new(1,0,0,8),
					Parent=H,
				},{ corner(4) })
				local Fill = create("Frame",{
					BackgroundColor3=Theme.Accent,
					Size=UDim2.new((val-mn)/(mx-mn),0,1,0),Parent=Bar,
				},{ corner(4) })
				-- Knob is a sibling of Fill inside Bar so it doesn't inherit Fill's scale
				local Knob = create("Frame",{
					BackgroundColor3=Color3.fromRGB(255,255,255),
					AnchorPoint=Vector2.new(0.5,0.5),
					Size=UDim2.new(0,14,0,14),
					Position=UDim2.new((val-mn)/(mx-mn),0,0.5,0),
					Parent=Bar,
				},{ corner(7) })

				local dragging=false
				local function upd(input)
					local rel = math.clamp((input.Position.X-Bar.AbsolutePosition.X)/Bar.AbsoluteSize.X,0,1)
					local raw = math.floor((mn+(mx-mn)*rel)/inc+0.5)*inc
					val = math.clamp(raw,mn,mx)
					local t = (val-mn)/(mx-mn)
					quickTween(Fill,{Size=UDim2.new(t,0,1,0)},0.05)
					quickTween(Knob,{Position=UDim2.new(t,0,0.5,0)},0.05)
					VL.Text=tostring(val)
					if c.Flag then CuteWare.Flags[c.Flag]=val end
					if c.Callback then c.Callback(val) end
				end
				Bar.InputBegan:Connect(function(i)
					if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
						dragging=true; upd(i)
					end
				end)
				UserInputService.InputEnded:Connect(function(i)
					if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then dragging=false end
				end)
				UserInputService.InputChanged:Connect(function(i)
					if dragging and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then upd(i) end
				end)
				if c.Flag then CuteWare.Flags[c.Flag]=val end
				return H
			end

			------------------------------------------------------------
