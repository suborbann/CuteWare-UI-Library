			------------------------------------------------------------
			function Section:CreateKeybind(c)
				c = c or {}
				local curKey  = c.CurrentKeybind or Enum.KeyCode.F
				local listening = false

				local H = create("Frame",{BackgroundTransparency=1,Size=UDim2.new(1,0,0,30),Parent=SH})
				create("TextLabel",{
					Text=c.Name or "Keybind",Font=Theme.Font,TextSize=13,
					TextColor3=Theme.Text,BackgroundTransparency=1,
					Size=UDim2.new(1,-80,1,0),TextXAlignment=Enum.TextXAlignment.Left,Parent=H,
				})
				local KB = create("TextButton",{
					Text=curKey.Name,Font=Theme.Font,TextSize=12,
					TextColor3=Theme.Text,BackgroundColor3=Theme.Tertiary,
					Size=UDim2.new(0,70,0,26),Position=UDim2.new(1,-70,0.5,-13),
					Parent=H,
				},{ corner(6) })
				KB.MouseButton1Click:Connect(function()
					listening=true; KB.Text="..."
					quickTween(KB,{BackgroundColor3=Theme.Accent},0.12)
				end)
				UserInputService.InputBegan:Connect(function(i,proc)
					if listening and i.UserInputType==Enum.UserInputType.Keyboard then
						curKey=i.KeyCode; KB.Text=curKey.Name; listening=false
						quickTween(KB,{BackgroundColor3=Theme.Tertiary},0.12)
						if c.Flag then CuteWare.Flags[c.Flag]=curKey end
						if c.Callback then c.Callback(curKey) end
					elseif not listening and not proc and i.KeyCode==curKey then
						if c.Pressed then c.Pressed() end
					end
				end)
				if c.Flag then CuteWare.Flags[c.Flag]=curKey end
				return H
			end

