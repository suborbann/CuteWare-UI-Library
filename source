							selectedSet[opt] = not selectedSet[opt]
							OptBtn.TextColor3 = selectedSet[opt] and Theme.Accent or Theme.SubText
							refreshLabel()
							local result = {}
							for _, o in ipairs(options) do if selectedSet[o] then table.insert(result, o) end end
							if flag then CuteWare.Flags[flag] = result end
							if ddConfig.Callback then ddConfig.Callback(result) end
