	--------------------------------------------------------------------
	-- SMOOTH DRAGGING
	-- When coming out of maximized via topbar drag, the window snaps so
	-- its center-X aligns under the cursor (like Windows/macOS behaviour).
	--------------------------------------------------------------------
	do
		local dragging = false
		local dragStart, startPos
		local targetPos

		clearDrag = function() targetPos=nil; dragging=false end

		local function overControls(pos)
			local a,s2 = Controls.AbsolutePosition, Controls.AbsoluteSize
			return pos.X>=a.X and pos.X<=a.X+s2.X and pos.Y>=a.Y and pos.Y<=a.Y+s2.Y
		end

		TopBar.InputBegan:Connect(function(input)
			if input.UserInputType ~= Enum.UserInputType.MouseButton1
			and input.UserInputType ~= Enum.UserInputType.Touch then return end
			if overControls(input.Position) then return end

			if maximized then
				-- restore and re-anchor window center under cursor
				local mx = input.Position.X
				local halfW = windowSize.X.Offset / 2
				local halfH = windowSize.Y.Offset / 2
				local newX  = mx - halfW
				local newY  = input.Position.Y - TOPBAR_H/2

				maximized = false
				MaxBtn.Text = "‚ĖĘ"
				Main.Size     = windowSize
				Main.Position = UDim2.new(0,newX,0,newY)
				windowPos     = Main.Position

				-- now start dragging immediately from this new anchor
				dragging  = true
				dragStart = input.Position
				startPos  = Main.Position
			else
				dragging  = true
				dragStart = input.Position
				startPos  = Main.Position
			end

			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging  = false
					windowPos = Main.Position
				end
			end)
		end)

		UserInputService.InputChanged:Connect(function(input)
			if maximized then return end
			if dragging and (input.UserInputType==Enum.UserInputType.MouseMovement
				or input.UserInputType==Enum.UserInputType.Touch) then
				local d = input.Position - dragStart
				targetPos = UDim2.new(
					startPos.X.Scale, startPos.X.Offset+d.X,
					startPos.Y.Scale, startPos.Y.Offset+d.Y
				)
			end
		end)

		RunService.RenderStepped:Connect(function(dt)
			if targetPos and not maximized then
				Main.Position = Main.Position:Lerp(targetPos, math.clamp(dt*16,0,1))
				windowPos = Main.Position
			end
		end)
	end

