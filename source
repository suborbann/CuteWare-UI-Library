					Parent = Box,
				})

				local Arrow = create("TextLabel", {
					Text = "вЦЉ",
					Font = Theme.Font,
					TextSize = 12,
					TextColor3 = Theme.SubText,
					BackgroundTransparency = 1,
					Size = UDim2.new(0, 24, 1, 0),
					Position = UDim2.new(1, -28, 0, 0),
					Parent = Box,
				})

				local OptionList = create("Frame", {
					BackgroundColor3 = Theme.Tertiary,
					Position = UDim2.new(0, 0, 0, 58),
					Size = UDim2.new(1, 0, 0, 0),
					Parent = Holder,
					ClipsDescendants = true,
				}, {
					corner(8),
					create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder }),
				})

				local selectedSet = {}
				if mode == "multi" and type(current) == "table" then
					for _, v in ipairs(current) do selectedSet[v] = true end
				end

				local function refreshLabel()
					if mode == "multi" then
						local names = {}
						for _, opt in ipairs(options) do
							if selectedSet[opt] then table.insert(names, opt) end
						end
						SelectedLabel.Text = #names > 0 and table.concat(names, ", ") or "None"
					else
						SelectedLabel.Text = tostring(current or "None")
					end
				end
				refreshLabel()

				local optionButtons = {}
				for i, opt in ipairs(options) do
					local isSelected = mode == "multi" and selectedSet[opt] or (mode == "single" and opt == current)
					local OptBtn = create("TextButton", {
						Text = tostring(opt),
						Font = Theme.Font,
						TextSize = 13,
						TextColor3 = isSelected and Theme.Accent or Theme.SubText,
						BackgroundColor3 = Theme.Tertiary,
