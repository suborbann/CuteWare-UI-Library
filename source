			------------------------------------------------------
			-- KEYBIND
			------------------------------------------------------
			function Section:CreateKeybind(kbConfig)
				kbConfig = kbConfig or {}
				local currentKey = kbConfig.CurrentKeybind or Enum.KeyCode.F
				local flag = kbConfig.Flag
				local listening = false

				local Holder = create("Frame", {
					BackgroundTransparency = 1,
					Size = UDim2.new(1, 0, 0, 30),
					Parent = SectionHolder,
				})
				create("TextLabel", {
					Text = kbConfig.Name or "Keybind",
					Font = Theme.Font,
					TextSize = 13,
					TextColor3 = Theme.Text,
					BackgroundTransparency = 1,
					Size = UDim2.new(1, -80, 1, 0),
					TextXAlignment = Enum.TextXAlignment.Left,
					Parent = Holder,
				})

				local KeyBtn = create("TextButton", {
					Text = currentKey.Name,
					Font = Theme.Font,
					TextSize = 12,
					TextColor3 = Theme.Text,
					BackgroundColor3 = Theme.Tertiary,
					Size = UDim2.new(0, 70, 0, 26),
					Position = UDim2.new(1, -70, 0.5, -13),
					Parent = Holder,
				}, { corner(6) })

				KeyBtn.MouseButton1Click:Connect(function()
					listening = true
					KeyBtn.Text = "..."
					quickTween(KeyBtn, { BackgroundColor3 = Theme.Accent }, 0.12)
				end)

				UserInputService.InputBegan:Connect(function(input, processed)
					if listening and input.UserInputType == Enum.UserInputType.Keyboard then
						currentKey = input.KeyCode
						KeyBtn.Text = currentKey.Name
						listening = false
						quickTween(KeyBtn, { BackgroundColor3 = Theme.Tertiary }, 0.12)
						if flag then CuteWare.Flags[flag] = currentKey end
						if kbConfig.Callback then kbConfig.Callback(currentKey) end
					elseif not listening and not processed and input.KeyCode == currentKey then
						if kbConfig.Pressed then kbConfig.Pressed() end
					end
				end)

				if flag then CuteWare.Flags[flag] = currentKey end
				return Holder
			end

