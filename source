--------------------------------------------------------------------
-- UTILITIES
--------------------------------------------------------------------
local function tween(instance, info, props)
	local t = TweenService:Create(instance, info, props)
	t:Play()
	return t
end

local function quickTween(instance, props, duration)
	return tween(instance, TweenInfo.new(duration or 0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props)
end

local function create(class, props, children)
	local inst = Instance.new(class)
	for prop, value in pairs(props or {}) do
		inst[prop] = value
	end
	for _, child in ipairs(children or {}) do
		child.Parent = inst
	end
	return inst
end

local function corner(radius)
	return create("UICorner", { CornerRadius = UDim.new(0, radius or 8) })
end

local function stroke(color, thickness, transparency)
	return create("UIStroke", {
		Color = color or Theme.Stroke,
		Thickness = thickness or 1,
		Transparency = transparency or 0,
	})
end

local function padding(all)
	return create("UIPadding", {
		PaddingTop = UDim.new(0, all),
		PaddingBottom = UDim.new(0, all),
		PaddingLeft = UDim.new(0, all),
		PaddingRight = UDim.new(0, all),
	})
end

-- HSV <-> Color3 helpers already handled by Color3.fromHSV / Color3:ToHSV()

local function darken(color, factor)
	factor = factor or 0.85
	return Color3.new(
		math.clamp(color.R * factor, 0, 1),
		math.clamp(color.G * factor, 0, 1),
		math.clamp(color.B * factor, 0, 1)
	)
end

-- ClipsDescendants only clips to the RECTANGULAR bounds of a frame, not to
-- the rounded shape a UICorner draws. So an opaque child panel (topbar,
-- tab list) sitting flush against Main's edges will visually square off
-- Main's rounded corners. To fix this we give panels that touch the
-- window's outer edge their OWN UICorner, then mask (flatten) whichever
-- corners are NOT on the outer edge with small same-color squares.
local function applyPanelCorners(panel, radius, keep)
	corner(radius).Parent = panel
	local color = panel.BackgroundColor3
	local masks = {}
	local function mask(name, pos)
		local m = create("Frame", {
			Name = name,
			BackgroundColor3 = color,
			BorderSizePixel = 0,
			Position = pos,
			Size = UDim2.new(0, radius, 0, radius),
			ZIndex = (panel.ZIndex or 1),
			Parent = panel,
		})
		masks[name] = m
		return m
	end
	if not keep.TopLeft then mask("MaskTL", UDim2.new(0, 0, 0, 0)) end
	if not keep.TopRight then mask("MaskTR", UDim2.new(1, -radius, 0, 0)) end
	if not keep.BottomLeft then mask("MaskBL", UDim2.new(0, 0, 1, -radius)) end
	if not keep.BottomRight then mask("MaskBR", UDim2.new(1, -radius, 1, -radius)) end
	return masks
end

