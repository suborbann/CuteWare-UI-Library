					Text=c.Name or "Dropdown",Font=Theme.Font,TextSize=13,
					TextColor3=Theme.Text,BackgroundTransparency=1,
					Size=UDim2.new(1,0,0,18),
					TextXAlignment=Enum.TextXAlignment.Left,Parent=H,
				})

				local Box = create("TextButton",{
					Text="",BackgroundColor3=Theme.Tertiary,
					Position=UDim2.new(0,0,0,22),Size=UDim2.new(1,0,0,32),
					Parent=H,
				},{ corner(8) })
				Box.MouseEnter:Connect(function() if not open then quickTween(Box,{BackgroundColor3=darken(Theme.Tertiary,0.75)},0.15) end end)
				Box.MouseLeave:Connect(function() if not open then quickTween(Box,{BackgroundColor3=Theme.Tertiary},0.15) end end)

				local SelLabel = create("TextLabel",{
					Text=tostring(cur or "None"),Font=Theme.Font,TextSize=13,
					TextColor3=Theme.Text,BackgroundTransparency=1,
					Size=UDim2.new(1,-32,1,0),Position=UDim2.new(0,10,0,0),
					TextXAlignment=Enum.TextXAlignment.Left,
					TextTruncate=Enum.TextTruncate.AtEnd,Parent=Box,
				})
				local Arrow = create("TextLabel",{
					Text="‚Ėĺ",Font=Theme.Font,TextSize=14,
					TextColor3=Theme.SubText,BackgroundTransparency=1,
					Size=UDim2.new(0,24,1,0),Position=UDim2.new(1,-28,0,0),Parent=Box,
				})

				-- OptionList is a sibling of H, parented to SH so it
				-- sits on top of elements below H instead of pushing them.
				-- We reposition it below H dynamically.
				local optH = #opts * 30
				local OptionList = create("Frame",{
					BackgroundColor3=Theme.Tertiary,
					Size=UDim2.new(1,-24,0,0),
					Position=UDim2.new(0,0,0,0),  -- set after render
					ZIndex=20,
					ClipsDescendants=true,
					Visible=false,
					Parent=SH,
				},{
					corner(8),
					create("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder}),
				})

				-- Update OptionList position to sit just below Box
				local function reposOptionList()
					OptionList.Position = UDim2.new(0,0,0, H.Position.Y.Offset+56)
				end
				task.defer(reposOptionList)

				local selSet = {}
				if mode=="multi" and type(cur)=="table" then
					for _,v in ipairs(cur) do selSet[v]=true end
				end

				local function refreshLabel()
					if mode=="multi" then
						local ns={}
						for _,o in ipairs(opts) do if selSet[o] then ns[#ns+1]=o end end
						SelLabel.Text = #ns>0 and table.concat(ns,", ") or "None"
					else
						SelLabel.Text = tostring(cur or "None")
					end
				end
				refreshLabel()

				local optBtns={}
				for i,opt in ipairs(opts) do
					local isSel = mode=="multi" and selSet[opt] or (mode=="single" and opt==cur)
					local OB = create("TextButton",{
						Text=tostring(opt),Font=Theme.Font,TextSize=13,
						TextColor3=isSel and Theme.Accent or Theme.SubText,
						BackgroundColor3=Theme.Tertiary,BackgroundTransparency=1,
						Size=UDim2.new(1,0,0,30),LayoutOrder=i,
						ZIndex=21,Parent=OptionList,
					})
					OB.MouseEnter:Connect(function() quickTween(OB,{BackgroundTransparency=0.6},0.1) end)
					OB.MouseLeave:Connect(function() quickTween(OB,{BackgroundTransparency=1},0.1) end)
					OB.MouseButton1Click:Connect(function()
						if mode=="multi" then
							selSet[opt]=not selSet[opt]
							OB.TextColor3=selSet[opt] and Theme.Accent or Theme.SubText
							refreshLabel()
							local res={}; for _,o in ipairs(opts) do if selSet[o] then res[#res+1]=o end end
							if c.Flag then CuteWare.Flags[c.Flag]=res end
							if c.Callback then c.Callback(res) end
						else
							cur=opt; refreshLabel()
							for _,b in pairs(optBtns) do b.TextColor3=Theme.SubText end
							OB.TextColor3=Theme.Accent
							if c.Flag then CuteWare.Flags[c.Flag]=cur end
							if c.Callback then c.Callback(cur) end
							-- close after selection in single mode
							open=false
							quickTween(Arrow,{Rotation=0},0.18)
							quickTween(OptionList,{Size=UDim2.new(1,-24,0,0)},0.18)
							task.wait(0.2); OptionList.Visible=false
							quickTween(Box,{BackgroundColor3=Theme.Tertiary},0.12)
						end
					end)
					optBtns[#optBtns+1]=OB
				end

				Box.MouseButton1Click:Connect(function()
					reposOptionList()
					open=not open
					quickTween(Arrow,{Rotation=open and 180 or 0},0.18)
					if open then
						OptionList.Visible=true
						OptionList.Size=UDim2.new(1,-24,0,0)
						quickTween(OptionList,{Size=UDim2.new(1,-24,0,optH)},0.18)
						quickTween(Box,{BackgroundColor3=darken(Theme.Tertiary,0.75)},0.12)
					else
						quickTween(OptionList,{Size=UDim2.new(1,-24,0,0)},0.18)
						task.wait(0.2); if not open then OptionList.Visible=false end
						quickTween(Box,{BackgroundColor3=Theme.Tertiary},0.12)
					end
				end)

				if c.Flag then CuteWare.Flags[c.Flag]=cur end
				return H
			end

