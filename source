					Position = UDim2.new(0.5, 0, h, 0),
					Parent = HueBar,
				}, { corner(2), stroke(Color3.fromRGB(0, 0, 0), 1) })

				-- SV –Ї–≤–∞–і—А–∞—В –°–Я–†–Р–Т–Р (—И–Є—А–Њ–Ї–Є–є)
				local SVBox = create("ImageLabel", {
					Image = "rbxassetid://4155801252",
					BackgroundColor3 = Color3.fromHSV(h, 1, 1),
					Size = UDim2.new(1, -24, 0, 130),
					Position = UDim2.new(0, 20, 0, 0),
					Parent = Picker,
				}, { corner(6) })

				local SVCursor = create("Frame", {
					AnchorPoint = Vector2.new(0.5, 0.5),
					Size = UDim2.new(0, 10, 0, 10),
					BackgroundColor3 = Color3.fromRGB(255, 255, 255),
					Position = UDim2.new(s, 0, 1 - v, 0),
					Parent = SVBox,
				}, { corner(5), stroke(Color3.fromRGB(0, 0, 0), 1) })

				local function updateColor()
					color = Color3.fromHSV(h, s, v)
					Preview.BackgroundColor3 = color
					SVBox.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
					if flag then CuteWare.Flags[flag] = color end
					if cpConfig.Callback then cpConfig.Callback(color) end
				end

				local draggingSV, draggingHue = false, false

				SVBox.InputBegan:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then draggingSV = true end
				end)
				HueBar.InputBegan:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then draggingHue = true end
				end)
				UserInputService.InputEnded:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
						draggingSV, draggingHue = false, false
					end
				end)
				UserInputService.InputChanged:Connect(function(input)
					if input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch then return end
					if draggingSV then
						local relX = math.clamp((input.Position.X - SVBox.AbsolutePosition.X) / SVBox.AbsoluteSize.X, 0, 1)
						local relY = math.clamp((input.Position.Y - SVBox.AbsolutePosition.Y) / SVBox.AbsoluteSize.Y, 0, 1)
						s, v = relX, 1 - relY
						SVCursor.Position = UDim2.new(s, 0, 1 - v, 0)
						updateColor()
					elseif draggingHue then
						local relY = math.clamp((input.Position.Y - HueBar.AbsolutePosition.Y) / HueBar.AbsoluteSize.Y, 0, 1)
						h = relY
						HueCursor.Position = UDim2.new(0.5, 0, h, 0)
						updateColor()
					end
				end)

				Preview.MouseButton1Click:Connect(function()
					open = not open
					quickTween(Picker, { Size = UDim2.new(1, 0, 0, open and 130 or 0) }, 0.2)
				end)
				Picker.Size = UDim2.new(1, 0, 0, 0)

				if flag then CuteWare.Flags[flag] = color end
				return Holder
			end

			------------------------------------------------------
			-- COLOR PICKER 2 (—И–Є—А–Њ–Ї–Є–є —А–∞–і—Г–ґ–љ—Л–є - —Б–ї–µ–≤–∞ –Ї–Њ–ї–µ—Б–Њ, —Б–њ—А–∞–≤–∞ SV)
			------------------------------------------------------
			function Section:CreateColorPicker2(cpConfig)
				cpConfig = cpConfig or {}
				local color = cpConfig.CurrentColor or Color3.fromRGB(255, 255, 255)
				local flag = cpConfig.Flag
				local open = false
				local h, s, v = color:ToHSV()

				local Holder = create("Frame", {
					BackgroundTransparency = 1,
					Size = UDim2.new(1, 0, 0, 0),
					AutomaticSize = Enum.AutomaticSize.Y,
					ClipsDescendants = true,
					Parent = SectionHolder,
				})

				local Header = create("Frame", {
					BackgroundTransparency = 1,
					Size = UDim2.new(1, 0, 0, 30),
					Parent = Holder,
				})
				create("TextLabel", {
					Text = cpConfig.Name or "Color",
					Font = Theme.Font,
					TextSize = 13,
					TextColor3 = Theme.Text,
					BackgroundTransparency = 1,
					Size = UDim2.new(1, -40, 1, 0),
					TextXAlignment = Enum.TextXAlignment.Left,
					Parent = Header,
				})

				local Preview = create("TextButton", {
					Text = "",
					BackgroundColor3 = color,
					Size = UDim2.new(0, 28, 0, 20),
					Position = UDim2.new(1, -28, 0.5, -10),
					Parent = Header,
				}, { corner(6), stroke(Theme.Stroke, 1) })

				local Picker = create("Frame", {
					BackgroundTransparency = 1,
					Position = UDim2.new(0, 0, 0, 34),
					Size = UDim2.new(1, 0, 0, 0),
					Parent = Holder,
					ClipsDescendants = true,
				})

				-- Hue –Ї–Њ–ї–µ—Б–Њ –°–Ы–Х–Т–Р
				local HueWheel = create("Frame", {
					Position = UDim2.new(0, 0, 0, 0),
					Size = UDim2.new(0, 160, 0, 160),
					Parent = Picker,
				}, { corner(10) })

				local wheelGradient = create("UIGradient", {
					Color = ColorSequence.new({
						ColorSequenceKeypoint.new(0.00, Color3.fromRGB(255, 0, 0)),
						ColorSequenceKeypoint.new(0.14, Color3.fromRGB(255, 255, 0)),
						ColorSequenceKeypoint.new(0.28, Color3.fromRGB(0, 255, 0)),
						ColorSequenceKeypoint.new(0.42, Color3.fromRGB(0, 255, 255)),
						ColorSequenceKeypoint.new(0.57, Color3.fromRGB(0, 0, 255)),
						ColorSequenceKeypoint.new(0.71, Color3.fromRGB(255, 0, 255)),
						ColorSequenceKeypoint.new(0.85, Color3.fromRGB(255, 100, 150)),
						ColorSequenceKeypoint.new(1.00, Color3.fromRGB(255, 0, 0)),
					}),
					Rotation = 90,
				})
				wheelGradient.Parent = HueWheel

				local HueWheelCursor = create("Frame", {
					AnchorPoint = Vector2.new(0.5, 0.5),
					Size = UDim2.new(0, 12, 0, 12),
					BackgroundColor3 = Color3.fromRGB(255, 255, 255),
					Position = UDim2.new(0.5 + math.cos((h - 0.5) * math.pi * 2) * 0.35, 0, 0.5 + math.sin((h - 0.5) * math.pi * 2) * 0.35, 0),
					Parent = HueWheel,
				}, { corner(6), stroke(Color3.fromRGB(0, 0, 0), 1) })

				-- SV –Ї–≤–∞–і—А–∞—В –°–Я–†–Р–Т–Р (–±–Њ–ї—М—И–Њ–є)
				local SVBox = create("ImageLabel", {
					Image = "rbxassetid://4155801252",
					BackgroundColor3 = Color3.fromHSV(h, 1, 1),
					Size = UDim2.new(1, -176, 0, 160),
					Position = UDim2.new(0, 168, 0, 0),
					Parent = Picker,
				}, { corner(8) })

				local SVCursor = create("Frame", {
					AnchorPoint = Vector2.new(0.5, 0.5),
					Size = UDim2.new(0, 10, 0, 10),
					BackgroundColor3 = Color3.fromRGB(255, 255, 255),
					Position = UDim2.new(s, 0, 1 - v, 0),
					Parent = SVBox,
				}, { corner(5), stroke(Color3.fromRGB(0, 0, 0), 1) })

				local function updateColor()
					color = Color3.fromHSV(h, s, v)
					Preview.BackgroundColor3 = color
					SVBox.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
					if flag then CuteWare.Flags[flag] = color end
					if cpConfig.Callback then cpConfig.Callback(color) end
				end

				local draggingSV, draggingHueWheel = false, false

				HueWheel.InputBegan:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then draggingHueWheel = true end
				end)
				SVBox.InputBegan:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then draggingSV = true end
				end)

				UserInputService.InputEnded:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
						draggingSV, draggingHueWheel = false, false
					end
				end)

				UserInputService.InputChanged:Connect(function(input)
					if input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch then return end
					
					if draggingHueWheel then
						local centerX = HueWheel.AbsolutePosition.X + HueWheel.AbsoluteSize.X / 2
						local centerY = HueWheel.AbsolutePosition.Y + HueWheel.AbsoluteSize.Y / 2
						local deltaX = input.Position.X - centerX
						local deltaY = input.Position.Y - centerY
						h = (math.atan2(deltaY, deltaX) / (math.pi * 2) + 1) % 1
						HueWheelCursor.Position = UDim2.new(0.5 + math.cos((h - 0.5) * math.pi * 2) * 0.35, 0, 0.5 + math.sin((h - 0.5) * math.pi * 2) * 0.35, 0)
						updateColor()
					elseif draggingSV then
						local relX = math.clamp((input.Position.X - SVBox.AbsolutePosition.X) / SVBox.AbsoluteSize.X, 0, 1)
						local relY = math.clamp((input.Position.Y - SVBox.AbsolutePosition.Y) / SVBox.AbsoluteSize.Y, 0, 1)
						s, v = relX, 1 - relY
						SVCursor.Position = UDim2.new(s, 0, 1 - v, 0)
						updateColor()
					end
				end)

				Preview.MouseButton1Click:Connect(function()
					open = not open
					quickTween(Picker, { Size = UDim2.new(1, 0, 0, open and 160 or 0) }, 0.2)
				end)
				Picker.Size = UDim2.new(1, 0, 0, 0)

				if flag then CuteWare.Flags[flag] = color end
				return Holder
			end

			------------------------------------------------------
			-- TEXTBOX
			------------------------------------------------------
			function Section:CreateTextbox(tbConfig)
				tbConfig = tbConfig or {}
				local flag = tbConfig.Flag

				local Holder = create("Frame", {
					BackgroundTransparency = 1,
					Size = UDim2.new(1, 0, 0, 52),
					Parent = SectionHolder,
				})
				create("TextLabel", {
					Text = tbConfig.Name or "Input",
					Font = Theme.Font,
					TextSize = 13,
					TextColor3 = Theme.Text,
					BackgroundTransparency = 1,
					Size = UDim2.new(1, 0, 0, 18),
					TextXAlignment = Enum.TextXAlignment.Left,
					Parent = Holder,
				})

				local Box = create("Frame", {
					BackgroundColor3 = Theme.Tertiary,
					Position = UDim2.new(0, 0, 0, 22),
					Size = UDim2.new(1, 0, 0, 30),
					Parent = Holder,
				}, { corner(8) })

				local Input = create("TextBox", {
					Text = tbConfig.CurrentValue or "",
					PlaceholderText = tbConfig.PlaceholderText or "Enter text...",
					Font = Theme.Font,
					TextSize = 13,
					TextColor3 = Theme.Text,
					PlaceholderColor3 = Theme.SubText,
					BackgroundTransparency = 1,
					Size = UDim2.new(1, -16, 1, 0),
					Position = UDim2.new(0, 8, 0, 0),
					ClearTextOnFocus = false,
					TextXAlignment = Enum.TextXAlignment.Left,
					Parent = Box,
				})

				Input.Focused:Connect(function() quickTween(Box, { BackgroundColor3 = Theme.AccentDark }, 0.15) end)
				Input.FocusLost:Connect(function(enterPressed)
					quickTween(Box, { BackgroundColor3 = Theme.Tertiary }, 0.15)
					if flag then CuteWare.Flags[flag] = Input.Text end
					if tbConfig.Callback then tbConfig.Callback(Input.Text, enterPressed) end
				end)

				if flag then CuteWare.Flags[flag] = Input.Text end
				return Holder
			end

			------------------------------------------------------
			-- KEYBIND
			------------------------------------------------------
			function Section:CreateKeybind(kbConfig)
				kbConfig = kbConfig or {}
				local currentKey = kbConfig.CurrentKeybind or Enum.KeyCode.F
				local flag = kbConfig.Flag
				local listening = false

				local Holder = create("Frame", {
					BackgroundTransparency = 1,
					Size = UDim2.new(1, 0, 0, 30),
					Parent = SectionHolder,
				})
				create("TextLabel", {
					Text = kbConfig.Name or "Keybind",
					Font = Theme.Font,
					TextSize = 13,
					TextColor3 = Theme.Text,
					BackgroundTransparency = 1,
					Size = UDim2.new(1, -80, 1, 0),
					TextXAlignment = Enum.TextXAlignment.Left,
					Parent = Holder,
				})

				local KeyBtn = create("TextButton", {
					Text = currentKey.Name,
					Font = Theme.Font,
					TextSize = 12,
					TextColor3 = Theme.Text,
					BackgroundColor3 = Theme.Tertiary,
					Size = UDim2.new(0, 70, 0, 26),
					Position = UDim2.new(1, -70, 0.5, -13),
					Parent = Holder,
				}, { corner(6) })

				KeyBtn.MouseButton1Click:Connect(function()
					listening = true
					KeyBtn.Text = "..."
					quickTween(KeyBtn, { BackgroundColor3 = Theme.Accent }, 0.12)
				end)

				UserInputService.InputBegan:Connect(function(input, processed)
					if listening and input.UserInputType == Enum.UserInputType.Keyboard then
						currentKey = input.KeyCode
						KeyBtn.Text = currentKey.Name
						listening = false
						quickTween(KeyBtn, { BackgroundColor3 = Theme.Tertiary }, 0.12)
						if flag then CuteWare.Flags[flag] = currentKey end
						if kbConfig.Callback then kbConfig.Callback(currentKey) end
					elseif not listening and not processed and input.KeyCode == currentKey then
						if kbConfig.Pressed then kbConfig.Pressed() end
					end
				end)

				if flag then CuteWare.Flags[flag] = currentKey end
				return Holder
			end

			------------------------------------------------------
			-- LABEL
			------------------------------------------------------
			function Section:CreateLabel(text)
				return create("TextLabel", {
					Text = text or "",
					Font = Theme.Font,
					TextSize = 13,
					TextColor3 = Theme.SubText,
					BackgroundTransparency = 1,
					Size = UDim2.new(1, 0, 0, 0),
					AutomaticSize = Enum.AutomaticSize.Y,
					TextWrapped = true,
					TextXAlignment = Enum.TextXAlignment.Left,
					Parent = SectionHolder,
				})
			end

			return Section
		end

		return Tab
	end

	return Window
end

return CuteWare
