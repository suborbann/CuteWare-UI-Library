	-- SMOOTH DRAGGING
	--------------------------------------------------------------
	do
		local dragging = false
		local dragStart, startPos
		local targetPos

		clearDragTarget = function()
			targetPos = nil
			dragging = false
		end

		local function isOverControls(pos)
			local abs, size2 = Controls.AbsolutePosition, Controls.AbsoluteSize
			return pos.X >= abs.X and pos.X <= abs.X + size2.X and pos.Y >= abs.Y and pos.Y <= abs.Y + size2.Y
		end

		TopBar.InputBegan:Connect(function(input)
			if input.UserInputType ~= Enum.UserInputType.MouseButton1 and input.UserInputType ~= Enum.UserInputType.Touch then return end
			if isOverControls(input.Position) then return end

			if maximized then
				restoreFromMaximize()
				return
			end

			dragging = true
			dragStart = input.Position
			startPos = Main.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
					windowPos = Main.Position
				end
			end)
		end)

		UserInputService.InputChanged:Connect(function(input)
			if maximized then return end
			if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
				local delta = input.Position - dragStart
				targetPos = UDim2.new(
					startPos.X.Scale, startPos.X.Offset + delta.X,
					startPos.Y.Scale, startPos.Y.Offset + delta.Y
				)
			end
		end)

		RunService.RenderStepped:Connect(function(dt)
			if targetPos and not maximized then
				Main.Position = Main.Position:Lerp(targetPos, math.clamp(dt * 16, 0, 1))
				windowPos = Main.Position
			end
		end)
	end

