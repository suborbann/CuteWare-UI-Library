function CuteWare:CreateWindow(config)
	config = config or {}
	local windowName = config.Name or "CuteWare"
	local subtitle = config.Subtitle -- can be nil now
	local size = config.Size or UDim2.new(0, 560, 0, 380)
	local backgroundImage = config.BackgroundImage
	local backgroundTransparency = config.BackgroundImageTransparency or 0.75

	local TOPBAR_HEIGHT = 38

	local Window = {}
	Window.Tabs = {}

	local Main = create("Frame", {
		Name = "Main",
		BackgroundColor3 = Theme.Background,
		Size = size,
		Position = UDim2.new(0.5, -size.X.Offset / 2, 0.5, -size.Y.Offset / 2),
		Parent = self.ScreenGui,
		ClipsDescendants = true,
	}, {
		corner(12),
		stroke(Theme.Stroke, 1),
	})

	local BackgroundImage
	if backgroundImage then
		BackgroundImage = create("ImageLabel", {
			Name = "CustomBackground",
			Image = type(backgroundImage) == "number" and ("rbxassetid://" .. backgroundImage) or tostring(backgroundImage),
			BackgroundTransparency = 1,
			ImageTransparency = backgroundTransparency,
			ScaleType = Enum.ScaleType.Crop,
			Size = UDim2.new(1, 0, 1, 0),
			ZIndex = 0,
			Parent = Main,
		})
	end

	function Window:SetBackgroundImage(imageId, transparency)
		if not BackgroundImage then
			BackgroundImage = create("ImageLabel", {
				Name = "CustomBackground",
				BackgroundTransparency = 1,
				ScaleType = Enum.ScaleType.Crop,
				Size = UDim2.new(1, 0, 1, 0),
				ZIndex = 0,
				Parent = Main,
			})
		end
		BackgroundImage.Image = type(imageId) == "number" and ("rbxassetid://" .. imageId) or tostring(imageId)
		BackgroundImage.ImageTransparency = transparency or backgroundTransparency
	end

	Main.Size = UDim2.new(0, size.X.Offset * 0.9, 0, size.Y.Offset * 0.9)
	Main.BackgroundTransparency = 1
	quickTween(Main, { Size = size, BackgroundTransparency = 0 }, 0.28)

	-- TOP BAR --------------------------------------------------------
	local TopBar = create("Frame", {
		Name = "TopBar",
		BackgroundColor3 = Theme.Secondary,
		Size = UDim2.new(1, 0, 0, TOPBAR_HEIGHT),
		Parent = Main,
	})
	-- Top corners always rounded; bottom corners masked flat normally, but
	-- revealed (rounded) when minimized since the topbar becomes the whole window.
	local topBarMasks = applyPanelCorners(TopBar, 12, { TopLeft = true, TopRight = true, BottomLeft = false, BottomRight = false })

	if subtitle and subtitle ~= "" then
		create("TextLabel", {
			Text = windowName,
			Font = Theme.FontBold,
			TextSize = 16,
			TextColor3 = Theme.Text,
			BackgroundTransparency = 1,
			Position = UDim2.new(0, 16, 0, 4),
			Size = UDim2.new(1, -110, 0, 18),
			TextXAlignment = Enum.TextXAlignment.Left,
			Parent = TopBar,
		})
		create("TextLabel", {
			Text = subtitle,
			Font = Theme.Font,
			TextSize = 12,
			TextColor3 = Theme.SubText,
			BackgroundTransparency = 1,
			Position = UDim2.new(0, 16, 0, 20),
			Size = UDim2.new(1, -110, 0, 14),
			TextXAlignment = Enum.TextXAlignment.Left,
			Parent = TopBar,
		})
	else
		create("TextLabel", {
			Text = windowName,
			Font = Theme.FontBold,
			TextSize = 20,
			TextColor3 = Theme.Text,
			BackgroundTransparency = 1,
			Position = UDim2.new(0, 16, 0, 0),
			Size = UDim2.new(1, -110, 1, 0),
			TextXAlignment = Enum.TextXAlignment.Left,
			Parent = TopBar,
		})
	end

	-- window control buttons (minimize / maximize / close) -----------
	local Controls = create("Frame", {
		BackgroundTransparency = 1,
		AnchorPoint = Vector2.new(1, 0.5),
		Position = UDim2.new(1, -10, 0.5, 0),
		Size = UDim2.new(0, 96, 0, 26),
		Parent = TopBar,
	}, {
		create("UIListLayout", {
			FillDirection = Enum.FillDirection.Horizontal,
			HorizontalAlignment = Enum.HorizontalAlignment.Right,
			VerticalAlignment = Enum.VerticalAlignment.Center,
			Padding = UDim.new(0, 4),
			SortOrder = Enum.SortOrder.LayoutOrder,
		}),
	})

	local function makeControlButton(text, hoverBg, hoverText, layoutOrder)
		local Btn = create("TextButton", {
			Text = text,
			Font = Theme.FontBold,
			TextSize = 15,
			TextColor3 = Theme.SubText,
			BackgroundColor3 = hoverBg,
			BackgroundTransparency = 1,
			Size = UDim2.new(0, 28, 0, 26),
			LayoutOrder = layoutOrder,
			Parent = Controls,
		}, { corner(6) })
		Btn.MouseEnter:Connect(function()
			quickTween(Btn, { BackgroundTransparency = 0, TextColor3 = hoverText }, 0.15)
		end)
		Btn.MouseLeave:Connect(function()
			quickTween(Btn, { BackgroundTransparency = 1, TextColor3 = Theme.SubText }, 0.15)
		end)
		return Btn
	end

	local MinimizeBtn = makeControlButton("‚ÄĒ", darken(Theme.Tertiary, 0.9), Theme.Accent, 1)
	local MaximizeBtn = makeControlButton("‚ĖĘ", darken(Theme.Tertiary, 0.9), Theme.Accent, 2)
	local CloseBtn = makeControlButton("√ó", darken(Theme.Error, 0.5), Theme.Text, 3)

	--------------------------------------------------------------
	-- MINIMIZE / MAXIMIZE
	--------------------------------------------------------------
	-- IMPORTANT: we track the window's "restored" size/position in plain
	-- variables (windowSize / windowPos) instead of reading Main.Size /
	-- Main.Position at click time. Reading those properties directly was the
	-- actual bug behind "minimize doesn't open back up": if you clicked
	-- while a tween was still mid-flight, you'd read a PARTIAL, in-between
	-- value and store that as the size/position to restore to, so the
	-- "restore" tween would animate to a wrong (sometimes near-zero) size.
	local minimized, maximized = false, false
	local windowSize = size
	local windowPos = Main.Position

	local function setMinimizedVisual(isMin)
		topBarMasks.MaskBL.Visible = not isMin
		topBarMasks.MaskBR.Visible = not isMin
		MinimizeBtn.Text = isMin and "+" or "‚ÄĒ"
	end

	local clearDragTarget -- assigned once dragging is set up below

	local function restoreFromMaximize()
		maximized = false
		MaximizeBtn.Text = "‚ĖĘ"
		quickTween(Main, { Size = windowSize, Position = windowPos }, 0.28)
	end

	MinimizeBtn.MouseButton1Click:Connect(function()
		if maximized then return end -- restore from maximize first
		minimized = not minimized
		if clearDragTarget then clearDragTarget() end
		if minimized then
			quickTween(Main, { Size = UDim2.new(windowSize.X.Scale, windowSize.X.Offset, 0, TOPBAR_HEIGHT) }, 0.28)
		else
			quickTween(Main, { Size = windowSize }, 0.28)
		end
		setMinimizedVisual(minimized)
	end)

	MaximizeBtn.MouseButton1Click:Connect(function()
		if clearDragTarget then clearDragTarget() end
		if not maximized then
			if minimized then
				minimized = false
				setMinimizedVisual(false)
			end
			maximized = true
			quickTween(Main, { Size = UDim2.new(1, 0, 1, 0), Position = UDim2.new(0, 0, 0, 0) }, 0.28)
			MaximizeBtn.Text = "‚Ěź"
		else
			restoreFromMaximize()
		end
	end)

	CloseBtn.MouseButton1Click:Connect(function()
		quickTween(Main, { Size = UDim2.new(0, windowSize.X.Offset * 0.9, 0, windowSize.Y.Offset * 0.9), BackgroundTransparency = 1 }, 0.2)
		task.wait(0.2)
		Main.Visible = false
	end)

	--------------------------------------------------------------
	-- SMOOTH DRAGGING (tween-based, snappy but not instant)
	--------------------------------------------------------------
	do
		local dragging = false
		local dragStart, startPos
		local targetPos

		clearDragTarget = function()
			-- Without this, the RenderStepped loop below kept easing Main
			-- toward a stale targetPos left over from the last drag, which
			-- yanked the window back to its old spot right after
			-- maximize/minimize played their tween.
			targetPos = nil
			dragging = false
		end

		local function isOverControls(pos)
			local abs, size2 = Controls.AbsolutePosition, Controls.AbsoluteSize
			return pos.X >= abs.X and pos.X <= abs.X + size2.X and pos.Y >= abs.Y and pos.Y <= abs.Y + size2.Y
		end

		TopBar.InputBegan:Connect(function(input)
			if input.UserInputType ~= Enum.UserInputType.MouseButton1 and input.UserInputType ~= Enum.UserInputType.Touch then return end
			if isOverControls(input.Position) then return end -- don't start a drag from the buttons

			if maximized then
				-- clicking the topbar of a maximized window restores it,
				-- as requested, instead of trying to drag a fullscreen window
				restoreFromMaximize()
				return
			end

			dragging = true
			dragStart = input.Position
			startPos = Main.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
					windowPos = Main.Position
				end
			end)
		end)

		UserInputService.InputChanged:Connect(function(input)
			if maximized then return end
			if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
				local delta = input.Position - dragStart
				targetPos = UDim2.new(
					startPos.X.Scale, startPos.X.Offset + delta.X,
					startPos.Y.Scale, startPos.Y.Offset + delta.Y
				)
			end
		end)

