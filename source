			-- source of the "empty space" bug).
			------------------------------------------------------------
			function Section:CreateDropdown(c)
				c = c or {}
				local opts  = c.Options or {}
				local mode  = c.Mode or "single"
				local cur   = c.CurrentOption or opts[1]
				local open  = false

				-- Outer holder uses AutomaticSize=Y so section resizes
				-- when the list expands, but it MUST ClipsDescendants so
				-- the list doesn't leak outside during the tween.
				local H = create("Frame",{
					BackgroundTransparency=1,
					Size=UDim2.new(1,0,0,56),   -- fixed: label 18 + gap 4 + box 34 = 56
					Parent=SH,
					ClipsDescendants=false,      -- let list overflow visually (Z stacking)
				})

