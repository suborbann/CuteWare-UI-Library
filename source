        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(0.5, 0, 0.5, 0),
        Size = UDim2.new(0, 320, 0, 224), ZIndex = 901, Parent = Overlay,
    }, { corner(14), stroke(Theme.Stroke, 1) })

