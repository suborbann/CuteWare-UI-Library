function CuteWare:Init()
	-- destroy previous instance if re-executed
	local existing = PlayerGui:FindFirstChild("CuteWare")
	if existing then existing:Destroy() end

	local ScreenGui = create("ScreenGui", {
		Name = "CuteWare",
		ResetOnSpawn = false,
		ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
		DisplayOrder = 999, -- keeps CuteWare above other ScreenGuis (topmost)
		Parent = PlayerGui,
	})
	self.ScreenGui = ScreenGui

	-- Notification holder (top-right stack)
	local NotifHolder = create("Frame", {
		Name = "Notifications",
		BackgroundTransparency = 1,
		AnchorPoint = Vector2.new(1, 0),
		Position = UDim2.new(1, -20, 0, 20),
		Size = UDim2.new(0, 300, 1, -40),
		Parent = ScreenGui,
	}, {
		create("UIListLayout", {
			SortOrder = Enum.SortOrder.LayoutOrder,
			Padding = UDim.new(0, 10),
			HorizontalAlignment = Enum.HorizontalAlignment.Right,
		})
	})
	self.NotifHolder = NotifHolder

	return self
end

