function CuteWare:CreateWindow(config)
	config = config or {}
	local windowName = config.Name or "CuteWare"
	local subtitle = config.Subtitle or "made with cuteware"
	local size = config.Size or UDim2.new(0, 560, 0, 380)

	local Window = {}
	Window.Tabs = {}

	local Main = create("Frame", {
		Name = "Main",
		BackgroundColor3 = Theme.Background,
		Size = size,
		Position = UDim2.new(0.5, -size.X.Offset / 2, 0.5, -size.Y.Offset / 2),
		Parent = self.ScreenGui,
		ClipsDescendants = true,
	}, {
		corner(12),
		stroke(Theme.Stroke, 1),
	})

	-- Fade / scale in on open
	Main.Size = UDim2.new(0, size.X.Offset * 0.9, 0, size.Y.Offset * 0.9)
	Main.BackgroundTransparency = 1
	quickTween(Main, { Size = size, BackgroundTransparency = 0 }, 0.28)

	-- TOP BAR --------------------------------------------------------
	local TopBar = create("Frame", {
		Name = "TopBar",
		BackgroundColor3 = Theme.Secondary,
		Size = UDim2.new(1, 0, 0, 46),
		Parent = Main,
	}, {
		corner(12),
	})
	-- cover bottom rounding of topbar so it looks flush with body
	create("Frame", {
		BackgroundColor3 = Theme.Secondary,
		BorderSizePixel = 0,
		Position = UDim2.new(0, 0, 1, -12),
		Size = UDim2.new(1, 0, 0, 12),
		Parent = TopBar,
	})

	create("TextLabel", {
		Text = windowName,
		Font = Theme.FontBold,
		TextSize = 16,
		TextColor3 = Theme.Text,
		BackgroundTransparency = 1,
		Position = UDim2.new(0, 16, 0, 6),
		Size = UDim2.new(1, -32, 0, 20),
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = TopBar,
	})
	create("TextLabel", {
		Text = subtitle,
		Font = Theme.Font,
		TextSize = 12,
		TextColor3 = Theme.SubText,
		BackgroundTransparency = 1,
		Position = UDim2.new(0, 16, 0, 24),
		Size = UDim2.new(1, -32, 0, 16),
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = TopBar,
	})

	-- close button
	local CloseBtn = create("TextButton", {
		Text = "√ó",
		Font = Theme.FontBold,
		TextSize = 20,
		TextColor3 = Theme.SubText,
		BackgroundTransparency = 1,
		Size = UDim2.new(0, 32, 0, 32),
		Position = UDim2.new(1, -40, 0, 7),
		Parent = TopBar,
	})
	CloseBtn.MouseEnter:Connect(function() quickTween(CloseBtn, { TextColor3 = Theme.Error }, 0.15) end)
	CloseBtn.MouseLeave:Connect(function() quickTween(CloseBtn, { TextColor3 = Theme.SubText }, 0.15) end)
	CloseBtn.MouseButton1Click:Connect(function()
		quickTween(Main, { Size = UDim2.new(0, size.X.Offset * 0.9, 0, size.Y.Offset * 0.9), BackgroundTransparency = 1 }, 0.2)
		task.wait(0.2)
		Main.Visible = false
	end)

	--------------------------------------------------------------
	-- SMOOTH DRAGGING (tween-based, snappy but not instant)
	--------------------------------------------------------------
	do
		local dragging = false
		local dragStart, startPos
		local targetPos

		TopBar.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				dragging = true
				dragStart = input.Position
				startPos = Main.Position
				input.Changed:Connect(function()
					if input.UserInputState == Enum.UserInputState.End then
						dragging = false
					end
				end)
			end
		end)

		UserInputService.InputChanged:Connect(function(input)
			if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
				local delta = input.Position - dragStart
				targetPos = UDim2.new(
					startPos.X.Scale, startPos.X.Offset + delta.X,
					startPos.Y.Scale, startPos.Y.Offset + delta.Y
				)
			end
		end)

		-- smoothing loop: eases Main.Position toward targetPos each frame (fast but fluid)
		RunService.RenderStepped:Connect(function(dt)
			if targetPos then
				Main.Position = Main.Position:Lerp(targetPos, math.clamp(dt * 16, 0, 1))
			end
		end)
	end

	-- TAB LIST (left side) -------------------------------------------
	local TabList = create("Frame", {
		Name = "TabList",
		BackgroundColor3 = Theme.Secondary,
		Position = UDim2.new(0, 0, 0, 46),
		Size = UDim2.new(0, 140, 1, -46),
		Parent = Main,
	}, {
		create("UIListLayout", { Padding = UDim.new(0, 4), SortOrder = Enum.SortOrder.LayoutOrder }),
		padding(10),
	})

	-- CONTENT AREA -----------------------------------------------------
	local ContentArea = create("Frame", {
		Name = "ContentArea",
		BackgroundTransparency = 1,
		Position = UDim2.new(0, 140, 0, 46),
		Size = UDim2.new(1, -140, 1, -46),
		Parent = Main,
	})

	--------------------------------------------------------------
	-- TAB CREATION
	--------------------------------------------------------------
	function Window:CreateTab(tabConfig)
		tabConfig = tabConfig or {}
		local tabName = tabConfig.Name or "Tab"

		local TabButton = create("TextButton", {
			Text = tabName,
			Font = Theme.Font,
			TextSize = 14,
			TextColor3 = Theme.SubText,
			BackgroundColor3 = Theme.Tertiary,
			BackgroundTransparency = 1,
			Size = UDim2.new(1, 0, 0, 34),
			Parent = TabList,
		}, { corner(8) })

		local Page = create("ScrollingFrame", {
			Name = tabName .. "Page",
			BackgroundTransparency = 1,
			Size = UDim2.new(1, 0, 1, 0),
			CanvasSize = UDim2.new(0, 0, 0, 0),
			AutomaticCanvasSize = Enum.AutomaticCanvasSize.Y,
			ScrollBarThickness = 4,
			ScrollBarImageColor3 = Theme.Accent,
			Visible = false,
			Parent = ContentArea,
		}, {
			padding(14),
			create("UIListLayout", { Padding = UDim.new(0, 10), SortOrder = Enum.SortOrder.LayoutOrder }),
		})

		local Tab = { Page = Page, Button = TabButton }

		local function selectTab()
			for _, t in pairs(Window.Tabs) do
				t.Page.Visible = false
				quickTween(t.Button, { BackgroundTransparency = 1, TextColor3 = Theme.SubText }, 0.15)
			end
			Page.Visible = true
			quickTween(TabButton, { BackgroundTransparency = 0, TextColor3 = Theme.Text }, 0.15)
		end

		TabButton.MouseButton1Click:Connect(selectTab)
		TabButton.MouseEnter:Connect(function()
			if not Page.Visible then quickTween(TabButton, { TextColor3 = Theme.Text }, 0.12) end
		end)
		TabButton.MouseLeave:Connect(function()
			if not Page.Visible then quickTween(TabButton, { TextColor3 = Theme.SubText }, 0.12) end
		end)

		table.insert(Window.Tabs, Tab)
		if #Window.Tabs == 1 then selectTab() end

		----------------------------------------------------------
		-- SECTION (with title text)
		----------------------------------------------------------
		function Tab:CreateSection(name)
			local SectionHolder = create("Frame", {
				BackgroundColor3 = Theme.Secondary,
				Size = UDim2.new(1, 0, 0, 0),
				AutomaticSize = Enum.AutomaticSize.Y,
				Parent = Page,
			}, {
				corner(10),
				stroke(Theme.Stroke, 1),
				padding(12),
				create("UIListLayout", { Padding = UDim.new(0, 8), SortOrder = Enum.SortOrder.LayoutOrder }),
			})

			create("TextLabel", {
				Text = name or "Section",
				Font = Theme.FontBold,
				TextSize = 14,
				TextColor3 = Theme.Text,
				BackgroundTransparency = 1,
				Size = UDim2.new(1, 0, 0, 18),
				TextXAlignment = Enum.TextXAlignment.Left,
				LayoutOrder = 0,
				Parent = SectionHolder,
			})

			local Section = { Holder = SectionHolder }

			------------------------------------------------------
			-- BUTTON
			------------------------------------------------------
			function Section:CreateButton(btnConfig)
				btnConfig = btnConfig or {}
				local Btn = create("TextButton", {
					Text = btnConfig.Name or "Button",
					Font = Theme.Font,
					TextSize = 13,
					TextColor3 = Theme.Text,
					BackgroundColor3 = Theme.Tertiary,
					Size = UDim2.new(1, 0, 0, 34),
					Parent = SectionHolder,
				}, { corner(8) })

				Btn.MouseEnter:Connect(function() quickTween(Btn, { BackgroundColor3 = Theme.AccentDark }, 0.15) end)
				Btn.MouseLeave:Connect(function() quickTween(Btn, { BackgroundColor3 = Theme.Tertiary }, 0.15) end)
				Btn.MouseButton1Down:Connect(function() quickTween(Btn, { Size = UDim2.new(1, -6, 0, 32) }, 0.08) end)
				Btn.MouseButton1Up:Connect(function() quickTween(Btn, { Size = UDim2.new(1, 0, 0, 34) }, 0.12) end)
				Btn.MouseButton1Click:Connect(function()
					if btnConfig.Callback then btnConfig.Callback() end
				end)
				return Btn
			end

			------------------------------------------------------
			-- TOGGLE
			------------------------------------------------------
			function Section:CreateToggle(togConfig)
				togConfig = togConfig or {}
				local state = togConfig.CurrentValue or false
				local flag = togConfig.Flag

				local Holder = create("Frame", {
					BackgroundTransparency = 1,
					Size = UDim2.new(1, 0, 0, 30),
					Parent = SectionHolder,
				})
				create("TextLabel", {
					Text = togConfig.Name or "Toggle",
					Font = Theme.Font,
					TextSize = 13,
					TextColor3 = Theme.Text,
					BackgroundTransparency = 1,
					Size = UDim2.new(1, -50, 1, 0),
					TextXAlignment = Enum.TextXAlignment.Left,
					Parent = Holder,
				})

				local Switch = create("Frame", {
					BackgroundColor3 = state and Theme.Accent or Theme.Tertiary,
					Size = UDim2.new(0, 42, 0, 22),
					Position = UDim2.new(1, -42, 0.5, -11),
					Parent = Holder,
				}, { corner(11) })

				local Knob = create("Frame", {
					BackgroundColor3 = Color3.fromRGB(255, 255, 255),
					Size = UDim2.new(0, 18, 0, 18),
					Position = state and UDim2.new(1, -20, 0.5, -9) or UDim2.new(0, 2, 0.5, -9),
					Parent = Switch,
				}, { corner(9) })

				local Click = create("TextButton", { BackgroundTransparency = 1, Text = "", Size = UDim2.new(1, 0, 1, 0), Parent = Holder })

				local function set(newState, fire)
					state = newState
					quickTween(Switch, { BackgroundColor3 = state and Theme.Accent or Theme.Tertiary }, 0.18)
					quickTween(Knob, { Position = state and UDim2.new(1, -20, 0.5, -9) or UDim2.new(0, 2, 0.5, -9) }, 0.18)
					if flag then CuteWare.Flags[flag] = state end
					if fire ~= false and togConfig.Callback then togConfig.Callback(state) end
				end

				Click.MouseButton1Click:Connect(function() set(not state) end)
				if flag then CuteWare.Flags[flag] = state end
				return { Set = set }
			end

			------------------------------------------------------
			-- SLIDER
			------------------------------------------------------
			function Section:CreateSlider(sldConfig)
				sldConfig = sldConfig or {}
				local min = sldConfig.Range and sldConfig.Range[1] or 0
				local max = sldConfig.Range and sldConfig.Range[2] or 100
				local increment = sldConfig.Increment or 1
				local value = sldConfig.CurrentValue or min
				local flag = sldConfig.Flag

				local Holder = create("Frame", {
					BackgroundTransparency = 1,
					Size = UDim2.new(1, 0, 0, 42),
					Parent = SectionHolder,
				})
				create("TextLabel", {
					Text = sldConfig.Name or "Slider",
					Font = Theme.Font,
					TextSize = 13,
					TextColor3 = Theme.Text,
					BackgroundTransparency = 1,
					Size = UDim2.new(1, -50, 0, 18),
					TextXAlignment = Enum.TextXAlignment.Left,
					Parent = Holder,
				})
				local ValueLabel = create("TextLabel", {
					Text = tostring(value),
					Font = Theme.Font,
					TextSize = 13,
					TextColor3 = Theme.SubText,
					BackgroundTransparency = 1,
					Size = UDim2.new(0, 50, 0, 18),
					Position = UDim2.new(1, -50, 0, 0),
					TextXAlignment = Enum.TextXAlignment.Right,
					Parent = Holder,
				})

				local Bar = create("Frame", {
					BackgroundColor3 = Theme.Tertiary,
					Position = UDim2.new(0, 0, 0, 26),
					Size = UDim2.new(1, 0, 0, 8),
					Parent = Holder,
				}, { corner(4) })

				local Fill = create("Frame", {
					BackgroundColor3 = Theme.Accent,
					Size = UDim2.new((value - min) / (max - min), 0, 1, 0),
					Parent = Bar,
				}, { corner(4) })

				local Knob = create("Frame", {
					BackgroundColor3 = Color3.fromRGB(255, 255, 255),
					AnchorPoint = Vector2.new(0.5, 0.5),
					Size = UDim2.new(0, 14, 0, 14),
					Position = UDim2.new((value - min) / (max - min), 0, 0.5, 0),
					Parent = Fill,
				}, { corner(7) })

				local dragging = false
				local function update(input)
					local relative = math.clamp((input.Position.X - Bar.AbsolutePosition.X) / Bar.AbsoluteSize.X, 0, 1)
					local raw = min + (max - min) * relative
					raw = math.floor(raw / increment + 0.5) * increment
					raw = math.clamp(raw, min, max)
					value = raw
					quickTween(Fill, { Size = UDim2.new((value - min) / (max - min), 0, 1, 0) }, 0.05)
					ValueLabel.Text = tostring(value)
					if flag then CuteWare.Flags[flag] = value end
					if sldConfig.Callback then sldConfig.Callback(value) end
				end

				Bar.InputBegan:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
						dragging = true
						update(input)
					end
				end)
				UserInputService.InputEnded:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
						dragging = false
					end
				end)
				UserInputService.InputChanged:Connect(function(input)
					if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
						update(input)
					end
				end)

				if flag then CuteWare.Flags[flag] = value end
				return Holder
			end

			------------------------------------------------------
			-- DROPDOWN
			------------------------------------------------------
			function Section:CreateDropdown(ddConfig)
				ddConfig = ddConfig or {}
				local options = ddConfig.Options or {}
				local current = ddConfig.CurrentOption or options[1]
				local flag = ddConfig.Flag
				local multi = ddConfig.MultipleOptions or false
				local open = false

				local Holder = create("Frame", {
					BackgroundTransparency = 1,
					Size = UDim2.new(1, 0, 0, 0),
					AutomaticSize = Enum.AutomaticSize.Y,
					Parent = SectionHolder,
					ClipsDescendants = true,
				})

				create("TextLabel", {
					Text = ddConfig.Name or "Dropdown",
					Font = Theme.Font,
					TextSize = 13,
					TextColor3 = Theme.Text,
					BackgroundTransparency = 1,
					Size = UDim2.new(1, 0, 0, 18),
					TextXAlignment = Enum.TextXAlignment.Left,
					Parent = Holder,
				})

				local Box = create("TextButton", {
					Text = "",
					BackgroundColor3 = Theme.Tertiary,
					Position = UDim2.new(0, 0, 0, 22),
					Size = UDim2.new(1, 0, 0, 32),
					Parent = Holder,
				}, { corner(8) })

				local SelectedLabel = create("TextLabel", {
					Text = tostring(current or "None"),
					Font = Theme.Font,
					TextSize = 13,
					TextColor3 = Theme.Text,
					BackgroundTransparency = 1,
					Size = UDim2.new(1, -30, 1, 0),
					Position = UDim2.new(0, 10, 0, 0),
					TextXAlignment = Enum.TextXAlignment.Left,
					TextTruncate = Enum.TextTruncate.AtEnd,
					Parent = Box,
				})

				local Arrow = create("TextLabel", {
					Text = "‚Ėĺ",
					Font = Theme.Font,
					TextSize = 14,
					TextColor3 = Theme.SubText,
					BackgroundTransparency = 1,
					Size = UDim2.new(0, 24, 1, 0),
					Position = UDim2.new(1, -28, 0, 0),
					Parent = Box,
				})

				local OptionList = create("Frame", {
					BackgroundColor3 = Theme.Tertiary,
					Position = UDim2.new(0, 0, 0, 58),
					Size = UDim2.new(1, 0, 0, 0),
					Parent = Holder,
				}, {
					corner(8),
					create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder }),
				})

				local selectedSet = {}
				if multi and type(current) == "table" then
					for _, v in ipairs(current) do selectedSet[v] = true end
				end

				local function refreshLabel()
					if multi then
						local names = {}
						for _, opt in ipairs(options) do
							if selectedSet[opt] then table.insert(names, opt) end
						end
						SelectedLabel.Text = #names > 0 and table.concat(names, ", ") or "None"
					else
						SelectedLabel.Text = tostring(current or "None")
					end
				end
				refreshLabel()

				local optionButtons = {}
				for i, opt in ipairs(options) do
					local OptBtn = create("TextButton", {
						Text = tostring(opt),
						Font = Theme.Font,
						TextSize = 13,
						TextColor3 = (not multi and opt == current) or (multi and selectedSet[opt]) and Theme.Accent or Theme.SubText,
						BackgroundColor3 = Theme.Tertiary,
						BackgroundTransparency = 1,
						Size = UDim2.new(1, 0, 0, 30),
						LayoutOrder = i,
						Parent = OptionList,
					})
					OptBtn.MouseEnter:Connect(function() quickTween(OptBtn, { BackgroundTransparency = 0.6 }, 0.12) end)
					OptBtn.MouseLeave:Connect(function() quickTween(OptBtn, { BackgroundTransparency = 1 }, 0.12) end)
					OptBtn.MouseButton1Click:Connect(function()
						if multi then
							selectedSet[opt] = not selectedSet[opt]
							OptBtn.TextColor3 = selectedSet[opt] and Theme.Accent or Theme.SubText
							refreshLabel()
							local result = {}
							for _, o in ipairs(options) do if selectedSet[o] then table.insert(result, o) end end
							if flag then CuteWare.Flags[flag] = result end
							if ddConfig.Callback then ddConfig.Callback(result) end
						else
							current = opt
							refreshLabel()
							for _, b in pairs(optionButtons) do b.TextColor3 = Theme.SubText end
							OptBtn.TextColor3 = Theme.Accent
							if flag then CuteWare.Flags[flag] = current end
							if ddConfig.Callback then ddConfig.Callback(current) end
						end
					end)
					table.insert(optionButtons, OptBtn)
				end

				local optionHeight = #options * 30
				Box.MouseButton1Click:Connect(function()
					open = not open
					quickTween(Arrow, { Rotation = open and 180 or 0 }, 0.2)
					quickTween(OptionList, { Size = UDim2.new(1, 0, 0, open and optionHeight or 0) }, 0.2)
				end)

				if flag then CuteWare.Flags[flag] = multi and current or current end
				return Holder
			end

			------------------------------------------------------
			-- COLOR PICKER
			------------------------------------------------------
			function Section:CreateColorPicker(cpConfig)
				cpConfig = cpConfig or {}
				local color = cpConfig.CurrentColor or Color3.fromRGB(255, 255, 255)
				local flag = cpConfig.Flag
				local open = false
				local h, s, v = color:ToHSV()

				local Holder = create("Frame", {
					BackgroundTransparency = 1,
					Size = UDim2.new(1, 0, 0, 0),
					AutomaticSize = Enum.AutomaticSize.Y,
					ClipsDescendants = true,
					Parent = SectionHolder,
				})

				local Header = create("Frame", {
					BackgroundTransparency = 1,
					Size = UDim2.new(1, 0, 0, 30),
					Parent = Holder,
				})
				create("TextLabel", {
					Text = cpConfig.Name or "Color",
					Font = Theme.Font,
					TextSize = 13,
					TextColor3 = Theme.Text,
					BackgroundTransparency = 1,
					Size = UDim2.new(1, -40, 1, 0),
					TextXAlignment = Enum.TextXAlignment.Left,
					Parent = Header,
				})

				local Preview = create("TextButton", {
					Text = "",
					BackgroundColor3 = color,
					Size = UDim2.new(0, 28, 0, 20),
					Position = UDim2.new(1, -28, 0.5, -10),
					Parent = Header,
				}, { corner(6), stroke(Theme.Stroke, 1) })

				local Picker = create("Frame", {
					BackgroundTransparency = 1,
					Position = UDim2.new(0, 0, 0, 34),
					Size = UDim2.new(1, 0, 0, 130),
					Parent = Holder,
				})

				-- Saturation/Value box
				local SVBox = create("ImageLabel", {
					Image = "rbxassetid://4155801252", -- standard SV gradient
					BackgroundColor3 = Color3.fromHSV(h, 1, 1),
					Size = UDim2.new(0, 130, 0, 130),
					Parent = Picker,
				}, { corner(8) })

				local SVCursor = create("Frame", {
					AnchorPoint = Vector2.new(0.5, 0.5),
					Size = UDim2.new(0, 10, 0, 10),
					BackgroundColor3 = Color3.fromRGB(255, 255, 255),
					Position = UDim2.new(s, 0, 1 - v, 0),
					Parent = SVBox,
				}, { corner(5), stroke(Color3.fromRGB(0, 0, 0), 1) })

				-- Hue slider
				local HueBar = create("Frame", {
					Position = UDim2.new(0, 146, 0, 0),
					Size = UDim2.new(1, -146, 0, 20),
					Parent = Picker,
				}, { corner(6) })

				local hueGradient = create("UIGradient", {
					Color = ColorSequence.new({
						ColorSequenceKeypoint.new(0.00, Color3.fromRGB(255, 0, 0)),
						ColorSequenceKeypoint.new(0.17, Color3.fromRGB(255, 255, 0)),
						ColorSequenceKeypoint.new(0.33, Color3.fromRGB(0, 255, 0)),
						ColorSequenceKeypoint.new(0.50, Color3.fromRGB(0, 255, 255)),
						ColorSequenceKeypoint.new(0.67, Color3.fromRGB(0, 0, 255)),
						ColorSequenceKeypoint.new(0.83, Color3.fromRGB(255, 0, 255)),
						ColorSequenceKeypoint.new(1.00, Color3.fromRGB(255, 0, 0)),
					}),
					Rotation = 90,
				})
				hueGradient.Parent = HueBar
				corner(6).Parent = HueBar

				local HueCursor = create("Frame", {
					AnchorPoint = Vector2.new(0.5, 0.5),
					Size = UDim2.new(1, 4, 0, 4),
					BackgroundColor3 = Color3.fromRGB(255, 255, 255),
					Position = UDim2.new(0.5, 0, h, 0),
					Parent = HueBar,
				}, { corner(2), stroke(Color3.fromRGB(0, 0, 0), 1) })

				local function updateColor()
					color = Color3.fromHSV(h, s, v)
					Preview.BackgroundColor3 = color
					SVBox.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
					if flag then CuteWare.Flags[flag] = color end
					if cpConfig.Callback then cpConfig.Callback(color) end
				end

				local draggingSV, draggingHue = false, false

				SVBox.InputBegan:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then draggingSV = true end
				end)
				HueBar.InputBegan:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then draggingHue = true end
				end)
				UserInputService.InputEnded:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
						draggingSV, draggingHue = false, false
					end
				end)
				UserInputService.InputChanged:Connect(function(input)
					if input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch then return end
					if draggingSV then
						local relX = math.clamp((input.Position.X - SVBox.AbsolutePosition.X) / SVBox.AbsoluteSize.X, 0, 1)
						local relY = math.clamp((input.Position.Y - SVBox.AbsolutePosition.Y) / SVBox.AbsoluteSize.Y, 0, 1)
						s, v = relX, 1 - relY
						SVCursor.Position = UDim2.new(s, 0, 1 - v, 0)
						updateColor()
					elseif draggingHue then
						local relY = math.clamp((input.Position.Y - HueBar.AbsolutePosition.Y) / HueBar.AbsoluteSize.Y, 0, 1)
						h = relY
						HueCursor.Position = UDim2.new(0.5, 0, h, 0)
						updateColor()
					end
				end)

				Preview.MouseButton1Click:Connect(function()
					open = not open
					quickTween(Picker, { Size = UDim2.new(1, 0, 0, open and 130 or 0) }, 0.2)
				end)
				Picker.Size = UDim2.new(1, 0, 0, 0)

				if flag then CuteWare.Flags[flag] = color end
				return Holder
			end

