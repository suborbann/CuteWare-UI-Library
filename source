-- UTILITIES
local function tween(obj, info, props)
    local t = TweenService:Create(obj, info, props); t:Play(); return t
end
local function quickTween(obj, props, dur)
    return tween(obj, TweenInfo.new(dur or 0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props)
end
local function create(class, props, children)
    local inst = Instance.new(class)
    for k,v in pairs(props or {}) do inst[k] = v end
    for _,c in ipairs(children or {}) do c.Parent = inst end
    return inst
end
local function corner(r)  return create("UICorner",  { CornerRadius = UDim.new(0, r or 8) }) end
local function stroke(col,thick,transp)
    return create("UIStroke", { Color=col or Theme.Stroke, Thickness=thick or 1, Transparency=transp or 0 })
end
local function padding(a)
    return create("UIPadding", { PaddingTop=UDim.new(0,a), PaddingBottom=UDim.new(0,a), PaddingLeft=UDim.new(0,a), PaddingRight=UDim.new(0,a) })
end
local function darken(c, f)
    f = f or 0.85
    return Color3.new(math.clamp(c.Rf,0,1), math.clamp(c.Gf,0,1), math.clamp(c.B*f,0,1))
end
-- lighten: mixes the color toward white by amount (0-1)
local function lighten(c, amount)
    amount = amount or 0.15
    return Color3.new(
        math.clamp(c.R + (1-c.R)*amount, 0, 1),
        math.clamp(c.G + (1-c.G)*amount, 0, 1),
        math.clamp(c.B + (1-c.B)*amount, 0, 1)
    )
end

-- Applies UICorner and square masks so a panel flush against the window
-- edge doesn't visually cut the window's rounded corners (ClipsDescendants
-- only clips to a rectangle, not to the UICorner shape).
local function applyPanelCorners(panel, radius, keep)
    corner(radius).Parent = panel
    local col = panel.BackgroundColor3
    local masks = {}
    local function mask(name, pos)
        local m = create("Frame", {
            Name=name, BackgroundColor3=col, BorderSizePixel=0,
            Position=pos, Size=UDim2.new(0,radius,0,radius),
            ZIndex=(panel.ZIndex or 1), Parent=panel,
        })
        masks[name] = m
    end
    if not keep.TopLeft    then mask("MaskTL", UDim2.new(0,0,0,0)) end
    if not keep.TopRight   then mask("MaskTR", UDim2.new(1,-radius,0,0)) end
    if not keep.BottomLeft then mask("MaskBL", UDim2.new(0,0,1,-radius)) end
    if not keep.BottomRight then mask("MaskBR", UDim2.new(1,-radius,1,-radius)) end
    return masks
end

-- Resolves a background/icon source into something an ImageLabel can use.
-- Accepts a numeric asset id, a "rbxassetid://..." string, or a raw
-- "http(s)://..." link. Roblox Image* instances can only ever display
-- Roblox assets, so http(s) links are downloaded and handed to the client
-- through the common writefile+getcustomasset executor pattern.
local imageCache = {}
local function resolveImage(source)
    if source == nil or source == "" then return nil end
    if typeof(source) == "number" then
        return "rbxassetid://" .. source
    end
    source = tostring(source)
    if source:match("^rbxassetid://") or source:match("^rbxthumb://") then
        return source
    end
    if source:match("^https?://") then
        if imageCache[source] then return imageCache[source] end
        local ok, result = pcall(function()
            if writefile and getcustomasset then
                local fileName = "cuteware_img_" .. tostring(#source) .. ".png"
                if not (isfile and isfile(fileName)) then
                    local bytes = game:HttpGet(source)
                    writefile(fileName, bytes)
                end
                return getcustomasset(fileName)
            end
            return nil
        end)
        if ok and result then
            imageCache[source] = result
            return result
        end
        warn("[CuteWare] This executor can't load images directly from a URL (needs writefile + getcustomasset). Upload the image to Roblox and use its asset id instead.")
        return nil
    end
    return "rbxassetid://" .. source
end

-- Material-style ripple: a circle grows from the click point to fill the
-- button, then fades. The tab's own TextLabel always has a higher ZIndex
-- than the ripple so the label is never covered.
local function spawnRipple(button, x, y, color, fillDuration, rippleZIndex)
    fillDuration = fillDuration or 0.35
    local w, h = button.AbsoluteSize.X, button.AbsoluteSize.Y
    local diameter = math.sqrt(ww + hh) * 2.05
    local circle = create("Frame", {
        BackgroundColor3 = color,
        BackgroundTransparency = 0.15,
        Size = UDim2.new(0, 0, 0, 0),
        Position = UDim2.new(0, x, 0, y),
        AnchorPoint = Vector2.new(0.5, 0.5),
        ZIndex = rippleZIndex or ((button.ZIndex or 1) + 1),
        Parent = button,
    }, { corner(9999) })
    tween(circle, TweenInfo.new(fillDuration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, diameter, 0, diameter),
    })
    quickTween(circle, { BackgroundTransparency = 1 }, fillDuration * 0.9)
    task.delay(fillDuration, function()
        if circle and circle.Parent then circle:Destroy() end
    end)
end

