                        if c.Flag then CuteWare.Flags[c.Flag]=curKey end
                        if c.Callback then c.Callback(curKey) end
                    elseif not listening and not proc and i.KeyCode==curKey then
                        if c.Pressed then c.Pressed() end
                    end
                end)
                if c.Flag then CuteWare.Flags[c.Flag]=curKey end
                return H
            end

            ------------------------------------------------------------
            function Section:CreateLabel(text)
                return create("TextLabel",{
                    Text=text or "",Font=Theme.Font,TextSize=13,
                    TextColor3=Theme.SubText,BackgroundTransparency=1,
                    Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,
                    TextWrapped=true,TextXAlignment=Enum.TextXAlignment.Left,
                    Parent=SH,
                })
            end

            return Section
        end -- CreateSection

        return Tab
    end -- CreateTab

    return Window
end -- CreateWindow

return CuteWare
