local CuteWare = loadstring(game:HttpGet("https://raw.githubusercontent.com/suborbann/CuteWare-UI-Library/refs/heads/main/source"))()
CuteWare:Init()

-- Key System (optional, set Enabled = false to skip)
CuteWare:CreateKeySystem({
    Enabled = true,  -- Set to true and add your key to enable
    Key     = "cutekey123",
    Title   = "CuteWare Access",
    Note    = "Enter your key to continue (cutekey123).",
    OnClose = function()
        CuteWare:Notify({
            Title   = "Denied",
            Content = "Invalid key or cancelled.",
            Duration = 3,
            Position = "TopRight"
        })
    end,
})

-- Create Main Window
local Window = CuteWare:CreateWindow({
    Name                        = "CuteWare Demo",
    Subtitle                    = "Full Feature Showcase",
    Size                        = UDim2.new(0, 600, 0, 450),
    Icon                        = 125089054351368,
    BackgroundImage             = "rbxassetid://128555281091950",
    BackgroundImageTransparency = 0.75,
    ToggleKeybind               = Enum.KeyCode.RightControl,
})

-- ============================================
-- TAB 1: BASIC ELEMENTS
-- ============================================
local Tab1 = Window:CreateTab({
    Name = "Basics",
    Icon = 128457643781626,
})

local Section1 = Tab1:CreateSection("Basic Controls")

Section1:CreateLabel("Welcome to CuteWare! Try all the controls below.")

Section1:CreateToggle({
    Name         = "Enable Feature",
    Flag         = "BasicToggle",
    CurrentValue = false,
    Callback     = function(state)
        print("Toggle state:", state)
    end,
})

Section1:CreateButton({
    Name     = "Click Me!",
    Callback = function()
        CuteWare:Notify({
            Title    = "Button Pressed",
            Content  = "You clicked the button!",
            Duration = 3,
            Position = "TopRight"
        })
    end,
})

Section1:CreateCloseButton({
    Name     = "Close Window",
    Callback = function()
        print("Window closing...")
    end,
})

-- ============================================
-- TAB 2: SLIDERS & INPUT
-- ============================================
local Tab2 = Window:CreateTab({
    Name = "Input",
    Icon = 128457643781626,
})

local Section2 = Tab2:CreateSection("Sliders & Text")

Section2:CreateSlider({
    Name         = "Speed Multiplier",
    Range        = {0, 100},
    Increment    = 5,
    CurrentValue = 50,
    Flag         = "SpeedMultiplier",
    Callback     = function(value)
        print("Speed set to:", value)
    end,
})

Section2:CreateSlider({
    Name         = "Volume Level",
    Range        = {0, 1},
    Increment    = 0.1,
    CurrentValue = 0.5,
    Flag         = "VolumeLevel",
    Callback     = function(value)
        print("Volume:", value)
    end,
})

Section2:CreateTextbox({
    Name            = "Player Name",
    PlaceholderText = "Enter a name...",
    CurrentValue    = "",
    Flag            = "PlayerName",
    Callback        = function(text, enterPressed)
        if enterPressed then
            CuteWare:Notify({
                Title    = "Name Set",
                Content  = "Player name: " .. text,
                Duration = 2,
                Position = "BottomRight"
            })
        end
    end,
})

Section2:CreateLabel("Enter your player name above and press Enter.")

-- ============================================
-- TAB 3: DROPDOWNS
-- ============================================
local Tab3 = Window:CreateTab({
    Name = "Dropdowns",
    Icon = 128457643781626,
})

local Section3 = Tab3:CreateSection("Single & Multi Select")

Section3:CreateDropdown({
    Name          = "Game Mode",
    Mode          = "single",
    Options       = {"Survival", "Creative", "Adventure", "Hardcore"},
    CurrentOption = "Survival",
    Flag          = "GameMode",
    Callback      = function(selected)
        print("Mode selected:", selected)
    end,
})

Section3:CreateDropdown({
    Name          = "Preferred Colors",
    Mode          = "multi",
    Options       = {"Red", "Blue", "Green", "Yellow", "Purple", "Orange"},
    CurrentOption = {"Red", "Blue"},
    Flag          = "PreferredColors",
    Callback      = function(selected)
        print("Colors selected:", table.concat(selected, ", "))
    end,
})

Section3:CreateMenuKeybindDropdown({
    Name          = "Menu Keybind",
    CurrentOption = "RCtrl",
    Callback      = function(name, keyCode)
        print("Menu keybind changed to:", name)
    end,
})

-- ============================================
-- TAB 4: COLORS & KEYBINDS
-- ============================================
local Tab4 = Window:CreateTab({
    Name = "Advanced",
    Icon = 128457643781626,
})

local Section4 = Tab4:CreateSection("Color & Keybind")

Section4:CreateColorPicker({
    Name         = "Accent Color",
    CurrentColor = Color3.fromRGB(255, 130, 180),
    Flag         = "AccentColor",
    Callback     = function(color)
        print("Color selected:", color)
    end,
})

Section4:CreateColorPicker({
    Name         = "Theme Color",
    CurrentColor = Color3.fromRGB(100, 150, 255),
    Flag         = "ThemeColor",
    Callback     = function(color)
        print("Theme color:", color)
    end,
})

Section4:CreateKeybind({
    Name           = "Activate Feature",
    CurrentKeybind = Enum.KeyCode.F,
    Flag           = "ActivateKeybind",
    Callback       = function(key)
        print("Keybind changed to:", key.Name)
    end,
    Pressed        = function()
        print("Keybind activated!")
        CuteWare:Notify({
            Title    = "Activated",
            Content  = "Feature is now active!",
            Duration = 2,
        })
    end,
})

local Section4B = Tab4:CreateSection("More Options")

Section4B:CreateKeybind({
    Name           = "Quick Action",
    CurrentKeybind = Enum.KeyCode.E,
    Flag           = "QuickActionKeybind",
    Callback       = function(key)
        print("Quick action bound to:", key.Name)
    end,
    Pressed        = function()
        print("Quick action pressed!")
    end,
})

