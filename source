			BackgroundColor3 = Theme.Tertiary,
			BackgroundTransparency = 1,
			Size = UDim2.new(1, 0, 0, 34),
			Parent = TabList,
		}, { corner(8) })

		-- UIScale drives the smooth hover "pop" without touching Size directly
		local TabScale = create("UIScale", { Scale = 1, Parent = TabButton })

		local Page = create("ScrollingFrame", {
			Name = tabName .. "Page",
			BackgroundTransparency = 1,
			Size = UDim2.new(1, 0, 1, 0),
			CanvasSize = UDim2.new(0, 0, 0, 0),
			ScrollBarThickness = 4,
			ScrollBarImageColor3 = Theme.Accent,
			Visible = false,
			Parent = ContentArea,
		}, {
			padding(14),
			create("UIListLayout", { Padding = UDim.new(0, 10), SortOrder = Enum.SortOrder.LayoutOrder }),
		})

		-- Manual canvas sizing instead of AutomaticCanvasSize: some Roblox
		-- builds/executors don't expose that enum member at all (that's what
		-- threw "AutomaticCanvasSize is not a valid member of Enum"), so we
		-- just resize the canvas ourselves whenever the list layout's content
		-- size changes.
		local PageLayout = Page:FindFirstChildOfClass("UIListLayout")
		local function updateCanvas()
			Page.CanvasSize = UDim2.new(0, 0, 0, PageLayout.AbsoluteContentSize.Y + 28)
		end
		PageLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateCanvas)
		updateCanvas()

		-- Tab.Active is the single source of truth for "is this tab selected".
		-- Previously hover logic read TabButton/Page state directly, which
		-- could desync mid-tween (e.g. rapid clicking) and leave a tab's
		-- hover/active colors inconsistent. Storing it explicitly on the Tab
		-- fixes that race.
		local Tab = { Page = Page, Button = TabButton, Active = false }

		local function selectTab()
			for _, t in pairs(Window.Tabs) do
				t.Active = false
				t.Page.Visible = false
				quickTween(t.Button, { BackgroundTransparency = 1, TextColor3 = Theme.SubText }, 0.15)
			end
			Tab.Active = true
			Page.Visible = true
			quickTween(TabButton, { BackgroundTransparency = 0, TextColor3 = Theme.Text }, 0.15)
		end

		TabButton.MouseButton1Click:Connect(selectTab)
		TabButton.MouseEnter:Connect(function()
			if not Tab.Active then quickTween(TabButton, { TextColor3 = Theme.Text }, 0.12) end
			quickTween(TabScale, { Scale = 1.035 }, 0.15)
		end)
		TabButton.MouseLeave:Connect(function()
			if not Tab.Active then quickTween(TabButton, { TextColor3 = Theme.SubText }, 0.12) end
			quickTween(TabScale, { Scale = 1 }, 0.15)
		end)

		table.insert(Window.Tabs, Tab)
		if #Window.Tabs == 1 then selectTab() end

